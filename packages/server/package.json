{
  "name": "@time/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "clean:iterations:dry-run": "tsx scripts/cleanInvalidIterations.ts --dry-run",
    "clean:iterations:apply": "tsx scripts/cleanInvalidIterations.ts --apply"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.2",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "uuid": "^11.1.0",
    "webdav": "^5.8.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
